import numpy as np 
import matplotlib.pyplot as plt 
import pandas as pd 





data = pd.read_csv("atlas_z_to_ll.csv") 

# Lepton 1 
pt1 = data['pt1']
phi1 = data['phi1'] 
n1 = data['eta1'] 
E1 = data['E1'] 

# vector components 
px1 = pt1*np.cos(phi1) 
py1 = pt1*np.sin(phi1) 
pz1 = pt1*np.sinh(n1) 

# Lepton 2 

pt2 = data['pt2']
phi2 = data['phi2'] 
n2 = data['eta2'] 
E2 = data['E2'] 

# vector components 
px2 = pt2*np.cos(phi2) 
py2 = pt2*np.sin(phi2) 
pz2 = pt2*np.sinh(n2) 

# mass of lepton pair  
pxt = px1 + px2 
pyt = py1 + py2 
pzt = pz1 + pz2 
Et = E1 + E2 
M = np.sqrt(Et**2 - (pxt**2 + pyt**2 + pzt**2)) 

# Histogram 

fig, ax = plt.subplots() 

bins = np.linspace(80,100,41)

counts, bin_edges = np.histogram(M, bins=bins) 
errors = np.sqrt(counts) 
bin_centers = (bin_edges[:-1] + bin_edges[1:]) / 2
ax.errorbar(bin_centers, counts, yerr=errors, fmt='ko', markersize=4, capsize=2, label='Poisson error')
ax.hist(M, bins=bins, alpha=0.5, histtype='step', color = 'blue', label='Mass distribution')
ax.set_xlabel("Invariant Mass [GeV]") 
ax.set_ylabel("Number of Events") 
ax.set_title(" Reconstructed Z Boson Mass") 
plt.legend() 
































